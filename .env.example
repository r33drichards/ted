# Copy to .env and fill in before running `docker compose up`.
# Compose reads this file automatically.

# Required: your Anthropic API key. The worker uses this to stream Claude
# responses. Without it the worker starts but every turn fails.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for chat (default claude-opus-4-5).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Any long random string works for local dev. Used by Auth.js to sign the
# session JWT. Generate a real one for non-local use.
NEXTAUTH_SECRET=local-dev-secret-change-me

# Only read when running outside compose (e.g. `npm run webhook`).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=chat
WEBHOOK_PORT=8787
